---
import { t } from "../i18n/server";
---

<section id="converter" class="conv section">
  <div class="container-page">
    <p class="eyebrow" data-i18n="conv.eyebrow">{t("conv.eyebrow")}</p>
    <h2 class="display-lg section-title" data-i18n="conv.title">{t("conv.title")}</h2>
    <p class="section-lead" data-i18n="conv.lead">{t("conv.lead")}</p>

    <div class="conv-card card-soft">
      <div class="conv-row">
        <label class="conv-field conv-value">
          <span data-i18n="conv.value">{t("conv.value")}</span>
          <input id="conv-input" type="number" inputmode="decimal" step="any" value="10" />
        </label>
        <label class="conv-field">
          <span data-i18n="conv.from">{t("conv.from")}</span>
          <select id="conv-from" class="conv-select"></select>
        </label>
        <button id="conv-swap" class="conv-swap" type="button" aria-label="Swap units" title="Swap">⇄</button>
        <label class="conv-field">
          <span data-i18n="conv.to">{t("conv.to")}</span>
          <select id="conv-to" class="conv-select"></select>
        </label>
      </div>

      <div class="conv-out">
        <span class="eyebrow" data-i18n="conv.result">{t("conv.result")}</span>
        <strong id="conv-result">—</strong>
      </div>
    </div>

    <p id="conv-relatable" class="conv-relatable" aria-live="polite"></p>

    <div class="conv-all">
      <p class="eyebrow" data-i18n="conv.allunits">{t("conv.allunits")}</p>
      <div id="conv-grid" class="conv-grid"></div>
      <p class="conv-note" data-i18n="conv.px.note">{t("conv.px.note")}</p>
    </div>
  </div>
</section>

<script>
  import { convert, fmt, UNIT_LABELS, currentPpi, toMm, relatableLength, type Unit } from "../scripts/units.ts";

  const ALL: Unit[] = ["mm", "cm", "m", "in", "ft", "pt", "px"];
  const input = document.getElementById("conv-input") as HTMLInputElement;
  const fromSel = document.getElementById("conv-from") as HTMLSelectElement;
  const toSel = document.getElementById("conv-to") as HTMLSelectElement;
  const resultEl = document.getElementById("conv-result");
  const relatableEl = document.getElementById("conv-relatable");
  const grid = document.getElementById("conv-grid");

  ALL.forEach((u) => {
    for (const sel of [fromSel, toSel]) {
      const opt = document.createElement("option");
      opt.value = u;
      opt.textContent = UNIT_LABELS[u];
      sel.appendChild(opt);
    }
  });
  fromSel.value = "cm";
  toSel.value = "in";

  function update() {
    const v = parseFloat(input.value);
    const from = fromSel.value as Unit;
    const to = toSel.value as Unit;
    if (!isFinite(v)) {
      if (resultEl) resultEl.textContent = "—";
      if (relatableEl) relatableEl.textContent = "";
      if (grid) grid.innerHTML = "";
      return;
    }
    const ppi = currentPpi();
    const out = convert(v, from, to, ppi);
    if (resultEl) resultEl.textContent = `${fmt(out)} ${to}`;

    // relatable comparison
    const rel = relatableLength(toMm(v, from, ppi));
    if (relatableEl) relatableEl.textContent = rel ? `≈ ${rel.text}` : "";

    // every-unit grid
    if (grid) {
      grid.innerHTML = "";
      ALL.forEach((u) => {
        const cell = document.createElement("div");
        cell.className = "conv-cell";
        cell.innerHTML = `<span class="cu">${u}</span><span class="cv">${fmt(convert(v, from, u, ppi))}</span>`;
        grid.appendChild(cell);
      });
    }
  }

  input.addEventListener("input", update);
  fromSel.addEventListener("change", update);
  toSel.addEventListener("change", update);
  document.getElementById("conv-swap")?.addEventListener("click", () => {
    const a = fromSel.value;
    fromSel.value = toSel.value;
    toSel.value = a;
    update();
  });
  // recompute if calibration changes elsewhere (affects px)
  window.addEventListener("ror:calibration", update);
  update();
</script>

<style>
  .section {
    padding-block: 56px;
  }
  .section-title {
    margin: 8px 0 0;
  }
  .section-lead {
    margin: 12px 0 28px;
    max-width: 64ch;
    color: var(--color-body);
    font: 400 18px / 28px var(--font-sans);
  }
  .conv-card {
    background: var(--color-canvas);
    padding: 24px;
  }
  .conv-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 12px;
  }
  .conv-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font: 500 13px var(--font-sans);
    color: var(--color-body);
  }
  .conv-value {
    flex: 1 1 120px;
  }
  .conv-field input,
  .conv-select {
    height: 44px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    padding: 0 12px;
    font: 400 16px var(--font-sans);
    background: var(--color-canvas);
    color: var(--color-ink);
  }
  .conv-select {
    cursor: pointer;
    min-width: 160px;
  }
  .conv-field input:focus-visible,
  .conv-select:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
    border-color: var(--color-link);
  }
  .conv-swap {
    height: 44px;
    width: 44px;
    flex-shrink: 0;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    font-size: 18px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .conv-swap:hover {
    background: var(--color-canvas-soft-2);
  }
  .conv-out {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--color-hairline);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .conv-out strong {
    font: 600 32px var(--font-sans);
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }
  .conv-relatable {
    margin: 16px 0 0;
    font: 500 16px var(--font-sans);
    color: var(--color-link-deep);
  }
  .conv-all {
    margin-top: 32px;
  }
  .conv-grid {
    margin-top: 12px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 10px;
  }
  .conv-cell {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 14px;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
  }
  .conv-cell .cu {
    font: 500 12px var(--font-mono);
    text-transform: uppercase;
    color: var(--color-mute);
  }
  .conv-cell .cv {
    font: 600 18px var(--font-sans);
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .conv-note {
    margin: 14px 0 0;
    font: 400 13px var(--font-sans);
    color: var(--color-mute);
  }
  @media (max-width: 640px) {
    .section {
      padding-block: 40px;
    }
    .conv-card {
      padding: 18px;
    }
    .conv-row {
      align-items: stretch;
    }
    .conv-value {
      flex-basis: 100%;
    }
    .conv-field {
      flex: 1 1 40%;
    }
    .conv-select {
      min-width: 0;
      width: 100%;
    }
    .conv-swap {
      align-self: center;
    }
    .conv-out strong {
      font-size: 26px;
    }
  }</style>
