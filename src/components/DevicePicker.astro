---
import { t } from "../i18n/server";
import { DEVICE_COUNT } from "../scripts/devices";
export interface Props {
  id: string;
}
const { id } = Astro.props;
---

<div class="dp" data-device-picker id={id}>
  <button type="button" class="dp-trigger field" aria-haspopup="listbox" aria-expanded="false">
    <span class="dp-value" data-i18n="tool.device.placeholder">{t("tool.device.placeholder")}</span>
    <span class="dp-caret" aria-hidden="true">▾</span>
  </button>
  <div class="dp-panel" hidden>
    <input
      type="search"
      class="dp-search"
      placeholder={`${t("tool.device.search")} (${DEVICE_COUNT}+)`}
      data-i18n-ph="tool.device.search"
      aria-label="Search devices"
      autocomplete="off"
    />
    <ul class="dp-list" role="listbox"></ul>
    <p class="dp-empty" hidden data-i18n="tool.device.none">{t("tool.device.none")}</p>
  </div>
</div>

<style>
  .dp {
    position: relative;
    min-width: 220px;
  }
  @media (max-width: 640px) {
    .dp {
      min-width: 0;
      width: 100%;
    }
    .dp-panel {
      width: min(340px, 92vw);
    }
  }
  .dp-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    width: 100%;
    height: 38px;
    cursor: pointer;
    text-align: left;
    font: 500 14px var(--font-sans);
    color: var(--color-ink);
  }
  .dp-value {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .dp-caret {
    color: var(--color-mute);
    font-size: 11px;
    flex-shrink: 0;
  }
  .dp-panel {
    position: absolute;
    z-index: 30;
    top: calc(100% + 6px);
    left: 0;
    width: min(340px, 86vw);
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-float);
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .dp-panel[hidden] {
    display: none;
  }
  .dp-search {
    width: 100%;
    height: 38px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    padding: 0 12px;
    font: 400 14px var(--font-sans);
    background: var(--color-canvas-soft);
    color: var(--color-ink);
  }
  .dp-search:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
    border-color: var(--color-link);
  }
  .dp-list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 300px;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .dp-group {
    font: 600 11px var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-mute);
    padding: 10px 10px 4px;
    position: sticky;
    top: 0;
    background: var(--color-canvas);
  }
  .dp-option {
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    font: 400 14px var(--font-sans);
    color: var(--color-ink);
    cursor: pointer;
  }
  .dp-option:hover,
  .dp-option.is-active {
    background: var(--color-canvas-soft-2);
  }
  .dp-empty {
    margin: 0;
    padding: 10px;
    color: var(--color-mute);
    font: 400 14px var(--font-sans);
  }
</style>
