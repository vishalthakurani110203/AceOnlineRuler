---
import { t } from "../i18n/server";
---

<section id="accuracy" class="section">
  <div class="container-page accuracy-band card-soft">
    <div>
      <p class="eyebrow" data-i18n="acc.eyebrow">{t("acc.eyebrow")}</p>
      <h2 class="display-md acc-title" data-i18n="acc.title">{t("acc.title")}</h2>
    </div>
    <p class="accuracy-copy" data-i18n="acc.body">{t("acc.body")}</p>
  </div>
</section>

<style>
  .section {
    padding-block: 64px;
  }
  .accuracy-band {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 32px;
    align-items: center;
    padding: 40px;
  }
  .acc-title {
    margin: 6px 0 0;
  }
  .accuracy-copy {
    margin: 0;
    color: var(--color-body);
    font: 400 16px / 26px var(--font-sans);
  }
  @media (max-width: 860px) {
    .accuracy-band {
      grid-template-columns: 1fr;
      padding: 28px;
    }
  }
</style>
