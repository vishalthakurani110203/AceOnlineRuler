---
import { LANGUAGES } from "../i18n/index";
import { flagFor } from "../i18n/flags";
export interface Props {
  id?: string;
}
const { id = "lang-select" } = Astro.props;
---

<div class="lang" data-lang-picker id={id}>
  <button type="button" class="lang-trigger" aria-haspopup="listbox" aria-expanded="false">
    <span class="lang-flag" data-lang-current-flag set:html={flagFor("en")} />
    <span class="lang-name" data-lang-current-name>English</span>
    <span class="lang-caret" aria-hidden="true">▾</span>
    <span class="sr-only" data-i18n="lang.label">Language</span>
  </button>
  <ul class="lang-panel" role="listbox" tabindex="-1" hidden>
    {LANGUAGES.map((l) => (
      <li class="lang-option" role="option" data-code={l.code} aria-selected={l.code === "en"}>
        <span class="lang-flag" set:html={flagFor(l.code)} />
        <span class="lang-opt-name">{l.name}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .lang {
    position: relative;
  }
  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 32px;
    padding: 0 10px 0 10px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    background: var(--color-canvas);
    color: var(--color-ink);
    font: 500 13px var(--font-sans);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .lang-trigger:hover {
    background: var(--color-canvas-soft-2);
  }
  .lang-trigger:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }
  .lang-flag {
    display: inline-flex;
    width: 1.4em;
    height: 1em;
    flex-shrink: 0;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08);
  }
  .lang-flag :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
  .lang-name {
    min-width: 52px;
    text-align: left;
  }
  .lang-caret {
    color: var(--color-mute);
    font-size: 10px;
  }

  .lang-panel {
    position: absolute;
    z-index: 45;
    top: calc(100% + 6px);
    right: 0;
    min-width: 180px;
    max-height: 320px;
    overflow-y: auto;
    overscroll-behavior: contain;
    list-style: none;
    margin: 0;
    padding: 6px;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-modal);
  }
  .lang-panel[hidden] {
    display: none;
  }
  .lang-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    font: 400 14px var(--font-sans);
    color: var(--color-ink);
    cursor: pointer;
  }
  .lang-option:hover,
  .lang-option.is-active {
    background: var(--color-canvas-soft-2);
  }
  .lang-option[aria-selected="true"] {
    font-weight: 500;
  }
  .lang-option[aria-selected="true"]::after {
    content: "✓";
    margin-left: auto;
    color: var(--color-link);
    font-size: 12px;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* RTL: drop the panel from the left edge instead */
  :global([dir="rtl"]) .lang-panel {
    right: auto;
    left: 0;
  }
</style>
