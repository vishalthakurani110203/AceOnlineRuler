---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Calibrate from "../components/Calibrate.astro";
import RulerTool from "../components/RulerTool.astro";
import Accuracy from "../components/Accuracy.astro";
import Footer from "../components/Footer.astro";

const title = "Calibrate Your Screen — Ace Online Ruler";
const description =
  "Calibrate your screen for a pixel-perfect online ruler. Three methods: auto-detect your device, enter your screen diagonal, or match a credit card.";
const canonical = "https://aceonlineruler.com/calibrate/";
---

<Layout title={title} description={description} canonical={canonical}>
  <Header />
  <main>
    <Calibrate />
    <RulerTool defaultUnit="cm" />
    <Accuracy />
  </main>
  <Footer />
</Layout>
