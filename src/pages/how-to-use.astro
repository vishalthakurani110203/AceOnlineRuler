---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Guide from "../components/Guide.astro";
import Accuracy from "../components/Accuracy.astro";
import Footer from "../components/Footer.astro";

const title = "How to Use the Online Ruler — Ace Online Ruler";
const description =
  "Learn how to use the online ruler in three steps: calibrate your screen, choose your units and edges, then measure at true actual size.";
const canonical = "https://aceonlineruler.com/how-to-use/";
---

<Layout title={title} description={description} canonical={canonical}>
  <Header />
  <main>
    <Guide />
    <Accuracy />
  </main>
  <Footer />
</Layout>
