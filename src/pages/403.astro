---
import Layout from "../layouts/Layout.astro";
import ErrorPage from "../components/ErrorPage.astro";

const title = "Access Denied (403) — Ace Online Ruler";
const description = "You don't have permission to access this page.";
const canonical = "https://aceonlineruler.com/403/";
---

<Layout title={title} description={description} canonical={canonical} noindex={true}>
  <ErrorPage
    code="403"
    heading="Access to this page is restricted."
    message="You don't have permission to view this resource. If you reached this by mistake, head back to the ruler."
  />
</Layout>
