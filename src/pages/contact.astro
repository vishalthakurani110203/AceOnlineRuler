---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Contact Us — Ace Online Ruler";
const description =
  "Get in touch with the Ace Online Ruler team. Send feedback, report an issue, request a device for our calibration database, or ask a question.";
const canonical = "https://aceonlineruler.com/contact/";
const email = "hello@aceonlineruler.com";

const contactLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Ace Online Ruler",
  url: canonical,
  description,
};
const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Ace Online Ruler",
  url: "https://aceonlineruler.com/",
  email,
  contactPoint: {
    "@type": "ContactPoint",
    email,
    contactType: "customer support",
    availableLanguage: ["English"],
  },
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Header />
  <main>
    <section class="contact section">
      <div class="container-page contact-grid">
        <div class="contact-intro">
          <p class="eyebrow">Contact</p>
          <h1 class="display-lg contact-title">Get in touch.</h1>
          <p class="contact-lead">
            Questions, feedback, bug reports, or a device we should add to our calibration database?
            Send us a message and we'll get back to you.
          </p>

          <ul class="contact-points">
            <li>
              <span class="cp-label">Email</span>
              <a class="cp-value" href={`mailto:${email}`}>{email}</a>
            </li>
            <li>
              <span class="cp-label">Response time</span>
              <span class="cp-value">We usually reply within 2–3 business days.</span>
            </li>
            <li>
              <span class="cp-label">Help yourself first</span>
              <span class="cp-value">Many answers live on our <a href="/faq/">FAQ</a> and <a href="/how-to-use/">How to use</a> pages.</span>
            </li>
          </ul>
        </div>

        <form id="contact-form" class="contact-form card-soft" novalidate>
          <label class="cf-field">
            <span>Name</span>
            <input id="cf-name" name="name" type="text" autocomplete="name" required />
          </label>
          <label class="cf-field">
            <span>Email</span>
            <input id="cf-email" name="email" type="email" autocomplete="email" required />
          </label>
          <label class="cf-field">
            <span>Subject</span>
            <input id="cf-subject" name="subject" type="text" />
          </label>
          <label class="cf-field">
            <span>Message</span>
            <textarea id="cf-message" name="message" rows="6" required></textarea>
          </label>
          <button type="submit" class="btn-primary cf-submit">Send message</button>
          <p id="cf-note" class="cf-note" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(contactLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
</Layout>

<script is:inline define:vars={{ email }}>
  const form = document.getElementById("contact-form");
  const note = document.getElementById("cf-note");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const name = (document.getElementById("cf-name")).value.trim();
    const from = (document.getElementById("cf-email")).value.trim();
    const subject = (document.getElementById("cf-subject")).value.trim() || "Message from Ace Online Ruler";
    const message = (document.getElementById("cf-message")).value.trim();

    if (!name || !from || !message) {
      if (note) {
        note.textContent = "Please fill in your name, email and message.";
        note.classList.remove("ok");
      }
      return;
    }
    const body = `Name: ${name}%0AEmail: ${from}%0A%0A${encodeURIComponent(message)}`;
    window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${body}`;
    if (note) {
      note.textContent = "Opening your email app… if nothing happens, email us directly at " + email + ".";
      note.classList.add("ok");
    }
  });
</script>

<style>
  .section {
    padding-block: 56px;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .contact-title {
    margin: 8px 0 0;
  }
  .contact-lead {
    margin: 14px 0 24px;
    max-width: 46ch;
    color: var(--color-body);
    font: 400 18px / 28px var(--font-sans);
  }
  .contact-points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 16px;
  }
  .contact-points li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cp-label {
    font: 500 12px var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-mute);
  }
  .cp-value {
    font: 400 16px var(--font-sans);
    color: var(--color-ink);
  }
  .cp-value a,
  .contact-points a {
    color: var(--color-link);
    text-decoration: none;
  }
  .cp-value a:hover {
    text-decoration: underline;
  }

  .contact-form {
    background: var(--color-canvas);
    padding: 28px;
    display: grid;
    gap: 16px;
  }
  .cf-field {
    display: grid;
    gap: 6px;
    font: 500 13px var(--font-sans);
    color: var(--color-body);
  }
  .cf-field input,
  .cf-field textarea {
    width: 100%;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    font: 400 15px var(--font-sans);
    background: var(--color-canvas);
    color: var(--color-ink);
    resize: vertical;
  }
  .cf-field input:focus-visible,
  .cf-field textarea:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
    border-color: var(--color-link);
  }
  .cf-submit {
    justify-self: start;
  }
  .cf-note {
    margin: 0;
    min-height: 18px;
    font: 500 14px var(--font-sans);
    color: var(--color-error);
  }
  .cf-note.ok {
    color: var(--color-link-deep);
  }

  @media (max-width: 760px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
