---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import RulerTool from "../components/RulerTool.astro";
import SeoContent from "../components/SeoContent.astro";
import SeoFaq from "../components/SeoFaq.astro";
import Footer from "../components/Footer.astro";

const title = "Online Ruler — Actual Size Ruler in Inches, cm & mm | Free & Accurate";
const description =
  "Free online ruler that shows actual size in inches, cm and mm. Calibrate to your screen for an accurate, to-scale 12 inch online ruler tool that works on any device.";
const canonical = "https://aceonlineruler.com/";
---

<Layout title={title} description={description} canonical={canonical}>
  <Header />
  <main>
    <Hero />
    <RulerTool defaultUnit="cm" />
    <SeoContent />
    <SeoFaq />
  </main>
  <Footer />
</Layout>
