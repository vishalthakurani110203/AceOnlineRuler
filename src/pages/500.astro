---
import Layout from "../layouts/Layout.astro";
import ErrorPage from "../components/ErrorPage.astro";

const title = "Server Error (500) — Ace Online Ruler";
const description = "Something went wrong on our end. Please try again in a moment.";
const canonical = "https://aceonlineruler.com/500/";
---

<Layout title={title} description={description} canonical={canonical} noindex={true}>
  <ErrorPage
    code="500"
    heading="Something went wrong on our end."
    message="We hit an unexpected error. Please try again in a moment — your calibration is saved locally and won't be lost."
    showRetry={true}
  />
</Layout>
