---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import { EN } from "../i18n/strings";

const title = "FAQ — Ace Online Ruler";
const description =
  "Frequently asked questions about the online ruler: accuracy, calibration, saving settings, browser zoom, mobile support and privacy.";
const canonical = "https://aceonlineruler.com/faq/";

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [1, 2, 3, 4, 5, 6].map((n) => ({
    "@type": "Question",
    name: EN[`faq.q${n}`],
    acceptedAnswer: { "@type": "Answer", text: EN[`faq.a${n}`] },
  })),
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Header />
  <main>
    <Faq />
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
</Layout>
